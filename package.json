{
    "name": "git-mark",
    "version": "0.3.0",
    "private": false,
    "description": "Bookmark manager for git-backed resources.",
    "type": "module",
    "bin": {
        "gmk": "./bin/gmk.cjs",
        "git-mark-mcp": "./bin/git-mark-mcp.cjs"
    },
    "scripts": {
        "dev": "node --import tsx src/cli.ts",
        "start": "node --import tsx src/cli.ts",
        "mcp": "node --import tsx src/mcp.ts",
        "compile": "npx --yes --package typescript tsc -p tsconfig.json",
        "typecheck": "npx --yes --package typescript tsc -p tsconfig.json --noEmit",
        "test": "node --experimental-strip-types --test test/*.test.ts"
    },
    "engines": {
        "node": ">=24.0.0"
    },
    "dependencies": {
        "@inquirer/prompts": "^8.3.2",
        "tsx": "^4.20.5"
    },
    "devDependencies": {
        "@types/node": "^25.5.0"
    },
    "files": [
        "bin",
        "src",
        "README.md",
        "LICENSE"
    ]
}
